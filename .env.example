# ============================================================
# Options Trading Bot — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains live credentials.
# ============================================================


# ─── Polygon.io ───────────────────────────────────────────
# Required for: GEX wall detection, daily/5-min/15-min bars,
#               options chain snapshot, OCC price history.
#
# How to get:
#   1. Sign up at https://polygon.io/dashboard/signup
#   2. Starter tier minimum (~$29/month) — Free tier lacks
#      options data and has lower rate limits.
#   3. Dashboard → API Keys → copy your default key
#
POLYGON_API_KEY=YOUR_POLYGON_API_KEY_HERE


# ─── TastyTrade ───────────────────────────────────────────
# Required for: live order placement, position monitoring,
#               GTC TP orders, working order audit.
#
# How to get your username/password:
#   Your normal TastyTrade login credentials.
#   Use a paper/sandbox account for testing first.
#
TASTYTRADE_USERNAME=your_tastytrade_username
TASTYTRADE_PASSWORD=your_tastytrade_password

# Account number:
#   TastyTrade desktop app → top-right account dropdown
#   Format is typically letters + digits, e.g. 5WX12345
#
TASTYTRADE_ACCOUNT=YOUR_ACCOUNT_NUMBER

# Environment: "production" for live trading, "sandbox" for paper
TASTYTRADE_ENV=production

# OAuth2 credentials (only needed if using client credentials flow):
#   TastyTrade developer portal → https://developer.tastytrade.com
#   Create an OAuth2 app to get client_id / client_secret.
#   Most users authenticate with username/password only — leave blank.
#
TASTYTRADE_CLIENT_ID=
TASTYTRADE_CLIENT_SECRET=
TASTYTRADE_REFRESH_TOKEN=


# ─── Optional: Finnhub ────────────────────────────────────
# Only needed for IV Crush scanner (earnings calendar).
# Free tier: 60 calls/min — sufficient.
#
# How to get:
#   Sign up at https://finnhub.io → Dashboard → API Key
#
FINNHUB_API_KEY=
